{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"linter": {
		"rules": {
			"nursery": {
				"useSortedClasses": "off"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"useSortedAttributes": "off",
				"organizeImports": "off"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
