{
	"name": "moderniptvplayer",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"db:push": "turbo -F @moderniptvplayer/db db:push",
		"db:studio": "turbo -F @moderniptvplayer/db db:studio",
		"db:generate": "turbo -F @moderniptvplayer/db db:generate",
		"db:migrate": "turbo -F @moderniptvplayer/db db:migrate",
		"db:deploy": "turbo -F @moderniptvplayer/db db:deploy",
		"check": "biome check apps/web/src",
		"lint": "biome lint apps/web/src",
		"format": "biome format --write apps/web/src",
		"start": "turbo run start"
	},
	"dependencies": {
		"@moderniptvplayer/env": "workspace:*",
		"dotenv": "catalog:",
		"typescript": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.15",
		"@moderniptvplayer/config": "workspace:*",
		"@types/node": "^22.13.14",
		"turbo": "^2.9.11"
	},
	"packageManager": "pnpm@10.28.2"
}
